# ============================================
# 精酿啤酒连锁智能体矩阵 - 环境配置
# ============================================

# === 有赞云 API 配置 ===
YOUZAN_CLIENT_ID=your_youzan_client_id
YOUZAN_CLIENT_SECRET=your_youzan_client_secret
YOUZAN_KDT_ID=your_youzan_kdt_id
YOUZAN_API_BASE=https://open.youzanyun.com/api
YOUZAN_AUTH_BASE=https://open.youzanyun.com/auth/token

# === 有赞门店 API ===
YOUZAN_STORE_API_BASE=https://open.youzanyun.com/api
YOUZAN_STORE_SHOP_IDS=store_001,store_002,store_003,store_004,store_005,store_006

# === 总部财务系统 API ===
FINANCE_API_BASE=http://internal-finance.cleverbrew.com/api/v2
FINANCE_API_KEY=your_finance_api_key
FINANCE_SYSTEM_TYPE=yonyou

# === HR 系统 API ===
HR_API_BASE=http://internal-hr.cleverbrew.com/api/v2
HR_API_KEY=your_hr_api_key
HR_SYSTEM_TYPE=feishu

# === ERP 供应链 API ===
ERP_API_BASE=http://internal-erp.cleverbrew.com/api/v2
ERP_API_KEY=your_erp_api_key
ERP_SYSTEM_TYPE=yonyou_scm

# === OpenClaw 配置 ===
OPENCLAW_HOME=~/.openclaw
OPENCLAW_WORKSPACE=~/.openclaw/workspace
OPENCLAW_MODEL_DEFAULT=anthropic/claude-sonnet-4-5
OPENCLAW_MODEL_ORCHESTRATOR=anthropic/claude-opus-4-5
OPENCLAW_MAX_CONCURRENT=8

# === Redis (任务队列) ===
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# === 数据库 ===
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=clever_brew_agents
DB_USER=cleverbrew
DB_PASSWORD=

# === 门店硬件 ===
STORE_MAC_COUNT=6
STORE_MAC_MODEL=mac_mini_m4

# === 日志 ===
LOG_LEVEL=info
LOG_DIR=./logs

# === 定时任务开关 ===
CRON_ENABLED=true
CRON_SUPPLY_MONITOR=*/5 * * * *
CRON_INVENTORY_SYNC=*/15 * * * *
CRON_STORE_PATROL=0 */2 * * *
CRON_MARKETING_REPORT=0 6 * * 1
CRON_FINANCE_RECONCILE=0 2 * * *
CRON_HR_SCHEDULE=0 0 * * 1
CRON_ERP_SYNC=0 */1 * * *
